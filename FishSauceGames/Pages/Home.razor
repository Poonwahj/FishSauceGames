@page "/"

<PageTitle>Fish Sauce Games</PageTitle>

<section class="hero">
    <div class="hero-text">
        <h1>The Sauce</h1>
        <p>We're an indie game studio building VR games, first person games, and helpful apps!</p>
        <a href="/MineAwareVR" class="btn-primary">Explore</a>
    </div>
    <div class="hero-media">
        <!-- Drop your hero image or gif here: wwwroot/images/hero.gif -->
        <img src="images/SomeRandomClipsIntoGif.gif" alt="Fish Sauce Games gameplay" onerror="this.style.display='none'" />
    </div>
</section>

<section class="platforms">
    <div class="platforms-text">
        <h2>Our Platforms</h2>
        <p>We're focused on building games for the Meta Quest 2/3/pro and PC in Unity 6.</p>
        <p>We build apps for Windows and Android</p>
        <a href="/MineAwareVR" class="btn-primary">Explore</a>
    </div>
    <div class="hero-media">
        <!-- Drop images here: wwwroot/images/platforms-unreal.png and platforms-setup.jpeg -->
        <img src="images/UsingUnity.png" alt="Unity development" onerror="this.style.display='none'" />
    </div>
</section>
