---
import Layout from '../layouts/Layout.astro';
---
<Layout title="CountTrackula - Fish Sauce Games">
  <section class="project-hero">
    <div class="project-text">
      <h1>CountTrackula</h1>
      <p></p>
      <a href="/CountTrackula/App" class="btn-primary">Launch App</a>
    </div>
    <div class="project-media">
      <img src="/images/CountTrackula.png" alt="CountTrackula app" onerror="this.style.display='none'" />
    </div>
  </section>

  <section class="track-everything">
    <h2>Track everything!</h2>
    <p>Use Count Trackula to track anything and everything.</p>
    <p>Want to get into journalling? CountTrackula!</p>
    <p>Want to track your macros? CountTrackula!</p>
    <p>How about Workouts? CountTrackula!</p>
    <p>This app was built to track fitness, nutrition, habit, and health markers. Easily export to json for consumption by an LLM of your choice (They all read Json)</p>
    <p>This app integrates with your google drive so it can synchronize between devices. Install it on your phone, use it on your desktop, supports offline and manual sync as well.</p>
  </section>

  <section class="legal-links">
    <a href="/CountTrackula/PrivacyPolicy">Privacy Policy</a>
    <span class="divider">·</span>
    <a href="/CountTrackula/termsofservice">Terms of Service</a>
  </section>
</Layout>

<style>
  .project-hero {
    display: flex;
    align-items: center;
    min-height: calc(100vh - 90px);
    padding: 3rem 4rem;
    gap: 3rem;
  }

  .project-text {
    flex: 0 0 auto;
    max-width: 420px;
  }

  .project-text h1 {
    font-size: 3rem;
    font-weight: 800;
    margin-bottom: 1rem;
  }

  .project-text p {
    font-size: 1rem;
    color: #c0c8d8;
    line-height: 1.6;
    margin-bottom: 2rem;
  }

  .project-media {
    flex: 1;
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 300px;
    background-color: #000000;
    border-radius: 4px;
    overflow: hidden;
  }

  .project-media img {
    width: 100%;
    height: auto;
    display: block;
    max-height: 520px;
    object-fit: cover;
  }

  .track-everything {
    padding: 4rem 2rem;
    max-width: 860px;
  }

  .track-everything h2 {
    font-size: 2.5rem;
    font-weight: 800;
    margin-bottom: 1.25rem;
  }

  .track-everything p {
    color: #c0c8d8;
    line-height: 1.7;
  }

  .legal-links {
    padding: 2rem 2rem 4rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.9rem;
  }

  .legal-links a {
    color: #6b7a99;
  }

  .legal-links a:hover {
    color: #c0c8d8;
  }

  .divider {
    color: #3a4458;
  }

  @media (max-width: 768px) {
    .project-hero {
      flex-direction: column;
      padding: 2rem 1.5rem;
      min-height: auto;
    }

    .project-text {
      max-width: 100%;
    }
  }
</style>
