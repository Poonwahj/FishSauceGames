---
const path = Astro.url.pathname;
const isHome = path === '/';
const isMineAware = path.startsWith('/MineAwareVR') || path.startsWith('/mineawarevr');
const isCountTrackula = path.startsWith('/CountTrackula');
---
<nav class="navbar">
  <div class="navbar-inner">
    <div class="navbar-brand">
      <a href="/">
        <img src="/images/VectorizedLogoWithTextWhite.png" alt="Fish Sauce Games" class="navbar-logo" />
      </a>
    </div>
    <button class="navbar-hamburger" id="hamburger" aria-label="Toggle navigation">
      <span></span>
      <span></span>
      <span></span>
    </button>
    <div class="navbar-links" id="navbar-links">
      <a href="/" class={isHome ? 'active' : ''}>Home</a>
      <a href="/MineAwareVR" class={isMineAware ? 'active' : ''}>MineAwareVR</a>
      <a href="/CountTrackula" class={isCountTrackula ? 'active' : ''}>CountTrackula</a>
    </div>
  </div>
</nav>

<script>
  const hamburger = document.getElementById('hamburger');
  const links = document.getElementById('navbar-links');
  hamburger?.addEventListener('click', () => links?.classList.toggle('open'));
</script>

<style>
  .navbar {
    background-color: #0d1117;
    position: sticky;
    top: 0;
    z-index: 100;
    border-bottom: 1px solid #1e2530;
  }

  .navbar-inner {
    display: flex;
    align-items: center;
    width: 100%;
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 16px;
  }

  .navbar-brand a {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
  }

  .navbar-logo {
    height: 70px;
    width: auto;
    object-fit: contain;
    display: block;
  }

  .navbar-links {
    display: flex;
    align-items: center;
    gap: 2rem;
    margin-left: 64px;
  }

  .navbar-links a {
    color: #e05252;
    text-decoration: none;
    font-size: 1rem;
    font-weight: 500;
    transition: color 0.2s;
  }

  .navbar-links a:hover {
    color: #ff7070;
  }

  .navbar-links a.active {
    color: #ffffff;
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  .navbar-hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.25rem;
    margin-left: auto;
  }

  .navbar-hamburger span {
    display: block;
    width: 24px;
    height: 2px;
    background-color: #ffffff;
    border-radius: 2px;
  }

  @media (max-width: 640px) {
    .navbar-hamburger {
      display: flex;
    }

    .navbar-links {
      display: none;
      width: 100%;
      flex-direction: column;
      gap: 1rem;
      padding-top: 1rem;
    }

    .navbar-links.open {
      display: flex;
    }

    .navbar-inner {
      flex-wrap: wrap;
      padding-bottom: 1rem;
    }
  }
</style>
